# Bronze Tier Environment Configuration
# Copy this file to .env and fill in your values

# Required: Anthropic API Key for Claude Sonnet 4.5
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Optional: Vault path (default: ./obsidian_vault)
VAULT_PATH=./obsidian_vault

# Optional: Watch folder path (default: ./watch_inbox)
WATCH_PATH=./watch_inbox

# Bronze Tier Notes:
# - Only ANTHROPIC_API_KEY is required
# - No Gmail, social media, or other API credentials needed
# - All other Platinum features are disabled
